{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",

      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.key)",

      "Read(**/id_rsa)",
      "Read(**/id_rsa.pub)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.pub)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ecdsa.pub)",
      "Read(**/id_ed25519_sk)",
      "Read(**/id_ecdsa_sk)",
      "Read(**/id_dsa)",

      "Read(**/.pypirc)",
      "Read(**/.docker/config.json)",
      "Read(**/.netrc)"
    ],
    "allow": [
      "Bash(ls:*)"
    ]
  }
}
